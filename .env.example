# Docker Compose
DOCKER_USERNAME=
DOCKER_REPO=
IMAGE_TAG=

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mydb
POSTGRES_SSLMODE=disable
POSTGRES_LOG_MODE=error # options: silent, error, warn, info

# Server
SERVER_PORT=8080

# JWT
# Use a long, random secret in real environments, e.g. `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-secret

# Cookie
COOKIE_SECURE=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# CORS
# Must list concrete origins (not *) when CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,HEAD,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Length,Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true 
CORS_MAX_AGE=12h

# MinIO (object storage for generated QR images)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=payment-qr
MINIO_USE_SSL=false
MINIO_URL_EXPIRY=15m

# Payment / PromptPay payee (university)
PROMPTPAY_ID=0902745366
BILLER_ID=
BILLER_REF1=
BILLER_REF2=
PAYMENT_MERCHANT_NAME=SUT
PAYMENT_MERCHANT_CITY=Korat

# SMTP (outbound email)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@sut.ac.th
FROM_NAME=ASSET SUT